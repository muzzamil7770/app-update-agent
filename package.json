{
  "name": "@muzzamil7770/app-update-agent",
  "version": "1.0.1",
  "description": "Framework-agnostic Angular app version monitor — detects updates, clears cache, unregisters service workers, and reloads with pluggable UI",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@angular/core": ">=15.0.0",
    "sweetalert2": ">=11.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": true
    },
    "sweetalert2": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/core": "^19.0.0",
    "sweetalert2": "^11.0.0",
    "typescript": "~5.7.2"
  },
  "keywords": [
    "angular",
    "version",
    "update",
    "pwa",
    "service-worker",
    "cache",
    "sweetalert2",
    "auto-update",
    "app-update",
    "version-check",
    "cache-busting",
    "reload",
    "typescript"
  ],
  "author": {
    "name": "Mohammad Muzzamil",
    "url": "https://github.com/muzzamil7770"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/muzzamil7770"
  },
  "homepage": "https://github.com/muzzamil7770/app-update-agent#readme",
  "bugs": {
    "url": "https://github.com/muzzamil7770/app-update-agent/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/muzzamil7770/app-update-agent"
  }
}
